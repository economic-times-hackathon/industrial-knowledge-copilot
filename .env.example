# ── LLM — Groq (free tier) ──────────────────────────────────────────────────
# Get a free API key at: https://console.groq.com
# Supported models: llama-3.3-70b-versatile (recommended), mixtral-8x7b-32768
GROQ_API_KEY=gsk_...

# ── Embeddings — Google Gemini (free tier) ───────────────────────────────────
# Get a free API key at: https://aistudio.google.com/apikey
# Model: text-embedding-004 (768 dims, excellent quality, completely free)
GOOGLE_API_KEY=AIza...

# ── ChromaDB — local vector store ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Corpus root ───────────────────────────────────────────────────────────────
CORPUS_DIR=./corpus

# ── Ingestion settings ────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
EMBEDDING_MODEL=gemini-embedding-001

# ── RAG / LLM settings ────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
TOP_K_RETRIEVAL=8
