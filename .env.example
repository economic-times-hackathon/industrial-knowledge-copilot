# Copy this to .env and fill in your values
OPENAI_API_KEY=sk-...

# ChromaDB — local persistence directory
CHROMA_PERSIST_DIR=./chroma_db

# Corpus root (relative to project root)
CORPUS_DIR=./corpus

# Ingestion settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
EMBEDDING_MODEL=text-embedding-3-small

# RAG settings
LLM_MODEL=gpt-4o
TOP_K_RETRIEVAL=8
