# ── LLM — Groq (free tier) ──────────────────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Embeddings ───────────────────────────────────────────────────────────────
# Options: fastembed (local, no API key) | gemini (needs GOOGLE_API_KEY)
EMBEDDING_BACKEND=fastembed

# FastEmbed model — local ONNX inference, downloads ~130MB once on first run
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# Gemini embedding — only used when EMBEDDING_BACKEND=gemini
GOOGLE_API_KEY=AIza...
EMBEDDING_MODEL=gemini-embedding-001

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Corpus ───────────────────────────────────────────────────────────────────
CORPUS_DIR=./corpus

# ── Ingestion settings ───────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── RAG settings ─────────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
TOP_K_RETRIEVAL=8
